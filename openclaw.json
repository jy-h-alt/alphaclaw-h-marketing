{
  "agents": {
    "defaults": {
      "workspace": "/data/.openclaw/workspace",
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "models": {
        "anthropic/claude-opus-4-6": {}
      },
      "maxConcurrent": 8,
      "subagents": {
        "maxConcurrent": 6
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "trustedProxies": [
      "127.0.0.1"
    ],
    "controlUi": {
      "allowedOrigins": [
        "https://alphaclaw-xlz0.onrender.com"
      ]
    }
  },
  "session": {
    "dmScope": "per-channel-peer",
    "resetByType": {
      "thread": {
        "mode": "idle",
        "idleMinutes": 525600
      }
    }
  },
  "tools": {
    "profile": "full",
    "exec": {
      "security": "full",
      "strictInlineEval": false
    }
  },
  "plugins": {
    "entries": {
      "anthropic": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "usage-tracker": {
        "enabled": true
      }
    },
    "allow": [
      "telegram",
      "usage-tracker",
      "anthropic",
      "memory-core"
    ],
    "load": {
      "paths": [
        "/app/node_modules/@chrysb/alphaclaw/lib/plugin/usage-tracker"
      ]
    }
  },
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },
  "skills": {
    "install": {
      "nodeManager": "npm"
    }
  },
  "wizard": {
    "lastRunAt": "2026-04-24T05:04:17.724Z",
    "lastRunVersion": "2026.4.21",
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "meta": {
    "lastTouchedVersion": "2026.4.21",
    "lastTouchedAt": "2026-04-24T05:05:03.750Z"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "groups": {
        "-1003909100192": {
          "requireMention": false
        }
      },
      "groupAllowFrom": [
        "5641435850"
      ]
    }
  },
  "commands": {
    "restart": true
  },
  "hooks": {
    "internal": {
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": [
            "hooks/bootstrap/AGENTS.md",
            "hooks/bootstrap/TOOLS.md"
          ]
        }
      },
      "enabled": true
    }
  }
}